{
    "Database": {
        "DatabaseName": "StockTraderAgent-integrationtests"
    },
    "Global": {
        "Environment": "Development"
    },
    "KEYVAULT_URI": "https://test-keyvault.vault.azure.net/",
    "Logging": {
        "LogLevel": {
            "Azure.Core": "Error",
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.Hosting.Lifetime": "Information",
            "ChrisUsher.TradingStrat": "Debug",
            "ChrisUsher.Stocks.MarketData": "Debug",
            "Services.Tests": "Debug"
        }
    },
    "REPORT_BLOBS_CONNECTIONSTRING": "UseDevelopmentStorage=true",
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console",
            "Serilog.Sinks.File"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Azure.Core": "Error",
                "Microsoft": "Warning",
                "System": "Warning",
                "ChrisUsher.TradingStrat": "Debug",
                "ChrisUsher.Stocks.MarketData": "Debug",
                "Services.Tests": "Debug"
            }
        },
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
                }
            },
            {
                "Name": "File",
                "Args": {
                    "path": "../../../TestLogs/test-log-.log",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 7,
                    "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
                }
            }
        ]
    },
    "Tests": {
        "Environment": "Development"
    }
}